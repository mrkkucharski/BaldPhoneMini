<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?bald_background"
    android:orientation="vertical">

    <app.baldphone.neo.views.TitleBarView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:titleBarBackgroundColor="@color/color_3"
        app:titleBarTitle="@string/about" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Logo -->
            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_marginTop="8dp"
                android:layout_gravity="center_horizontal"
                android:contentDescription="@string/app_display_name"
                android:src="@mipmap/ic_launcher" />

            <!-- App Name -->
            <TextView
                android:id="@+id/about_app_name"
                style="@style/BackgroundText.Huge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/app_display_name"
                android:textStyle="bold" />

            <!-- Version -->
            <TextView
                android:id="@+id/about_version"
                style="@style/BackgroundText.Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:textSize="15sp"
                tools:text="Version X.Y.Z" />

            <!-- Tagline -->
            <TextView
                android:id="@+id/about_tagline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:paddingHorizontal="32dp"
                android:text="@string/about_tag_line"
                android:textColor="?attr/bald_stroke_color"
                android:textSize="15sp" />

            <!-- LINKS SECTION -->
            <TextView
                style="@style/AboutSectionTitle"
                android:text="@string/about_overview_section" />

            <com.bald.uriah.baldphone.views.BaldButton
                android:id="@+id/whats_new"
                style="@style/LinkRow.Icon"
                android:drawableStart="@drawable/link_external"
                android:text="@string/what_s_new" />

            <com.bald.uriah.baldphone.views.BaldButton
                android:id="@+id/web_page"
                style="@style/LinkRow.Icon"
                android:drawableStart="@drawable/link_external"
                android:text="@string/about_web_page" />

            <com.bald.uriah.baldphone.views.BaldButton
                android:id="@+id/faq"
                style="@style/LinkRow.Icon"
                android:drawableStart="@drawable/link_external"
                android:enabled="false"
                android:text="@string/about_faq"
                android:visibility="gone" />

            <!-- CREDITS SECTION -->
            <TextView
                style="@style/AboutSectionTitle"
                android:text="@string/about_credits_title" />

            <com.bald.uriah.baldphone.views.BaldButton
                android:id="@+id/credits"
                style="@style/LinkRow.Icon"
                android:drawableStart="@drawable/ic_people"
                android:text="@string/about_credits" />

            <!-- LEGAL SECTION -->
            <TextView
                style="@style/AboutSectionTitle"
                android:text="@string/about_legal_title" />

            <com.bald.uriah.baldphone.views.BaldButton
                android:id="@+id/item_license"
                style="@style/LinkRow.Icon"
                android:drawableStart="@drawable/link_external"
                android:text="@string/about_app_license" />

            <com.bald.uriah.baldphone.views.BaldButton
                android:id="@+id/third_party_licenses"
                style="@style/LinkRow.Icon"
                android:drawableStart="@drawable/link_external"
                android:text="@string/about_licenses" />

            <com.bald.uriah.baldphone.views.BaldButton
                android:id="@+id/item_privacy"
                style="@style/LinkRow.Icon"
                android:drawableStart="@drawable/link_external"
                android:text="@string/about_privacy_policy" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
