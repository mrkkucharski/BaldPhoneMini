<com.bald.uriah.baldphone.views.BaldLinearLayoutButton xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bt_add_contact"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="@drawable/style_for_buttons_transparent"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp">

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/add_outlined_on_background" />

    <TextView
        style="@style/BackgroundText.Medium.Plus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="@string/add_contact" />

</com.bald.uriah.baldphone.views.BaldLinearLayoutButton>
