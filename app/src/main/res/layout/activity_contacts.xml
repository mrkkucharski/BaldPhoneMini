<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <app.baldphone.neo.views.TitleBarView
        android:id="@+id/title_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:titleBarBackgroundColor="@color/color_1"
        app:titleBarTitle="@string/contacts" />

    <EditText
        android:id="@+id/search_edit_text"
        style="@style/EditText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/search_contact"
        android:importantForAutofill="no"
        android:inputType="textPersonName"
        android:minHeight="60dp"
        android:padding="12dp"
        android:paddingStart="50dp"
        android:textAlignment="viewStart"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title_bar" />

    <com.bald.uriah.baldphone.views.BaldImageButton
        android:id="@+id/bt_speak"
        android:layout_width="50dp"
        android:layout_height="0dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:src="@drawable/search_on_button"
        app:layout_constraintBottom_toBottomOf="@id/search_edit_text"
        app:layout_constraintStart_toStartOf="@id/search_edit_text"
        app:layout_constraintTop_toTopOf="@id/search_edit_text" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/contacts_recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:requiresFadingEdge="vertical"
        android:scrollbars="vertical"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toTopOf="@id/contacts_bottom_actions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_edit_text"
        app:layout_goneMarginBottom="0dp" />

    <TextView
        android:id="@+id/empty_state_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:gravity="center"
        android:text="@string/no_contacts_found"
        android:textSize="24sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_edit_text"
        tools:visibility="visible" />

    <!-- Bottom action bar -->
    <LinearLayout
        android:id="@+id/contacts_bottom_actions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_add_contact"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:background="@drawable/style_for_buttons_checkable"
            app:backgroundTint="@null"
            android:minHeight="56dp"
            android:text="@string/add_contact"
            android:textAllCaps="false"
            app:icon="@drawable/add_on_button"
            app:iconGravity="textStart"
            app:iconSize="28dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_favorites"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:background="@drawable/style_for_buttons_checkable"
            android:checkable="true"
            android:minHeight="56dp"
            android:text="@string/favorites"
            android:textAllCaps="false"
            app:backgroundTint="@null"
            app:icon="@drawable/star_on_button"
            app:iconGravity="textStart"
            app:iconSize="28dp"
            app:iconTint="@color/gold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
