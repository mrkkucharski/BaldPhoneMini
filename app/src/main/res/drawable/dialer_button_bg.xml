<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/bald_keyboard_key_pressed_background">

    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="#000000" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bald_button" />
            <corners android:radius="24dp" />
            <stroke
                android:width="1dp"
                android:color="?attr/bald_stroke_color" />
        </shape>
    </item>
</ripple>
