<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:endColor="@android:color/transparent"
                android:startColor="#20000000" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <!-- Button with ripple -->
    <item
        android:bottom="2dp"
        android:left="0dp"
        android:right="2dp"
        android:top="0dp">
        <ripple android:color="?attr/colorControlHighlight">
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="?bald_button" />
                    <corners android:radius="10dp" />
                    <stroke
                        android:width="1dp"
                        android:color="?attr/bald_stroke_color" />
                </shape>
            </item>
        </ripple>
    </item>
</layer-list>