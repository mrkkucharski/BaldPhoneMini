<resources>

    <style name="Theme.AppCompat.Light.NoActionBar.FullScreen" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowActionBar">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">?bald_background</item>
        <item name="bald_button_gold">@color/gold</item>
        <item name="bald_text_on_gold">@color/on_gold</item>
        <item name="android:actionBarStyle">@style/BaldActionBar</item>
        <item name="colorAccent">#fff</item>
    </style>

    <style name="bald_light" parent="Theme.AppCompat.Light.NoActionBar.FullScreen">
        <item name="bald_key_margin">@dimen/bald_key_margin</item>
        <item name="bald_background">@color/bald_background_light</item>
        <item name="bald_background_transparent">@color/bald_background_transparent_light</item>
        <item name="bald_button">@color/bald_button_light</item>
        <item name="bald_button_clicked">@color/bald_button_clicked_light</item>
        <item name="bald_button_corners_radius">@dimen/bald_button_corners_radius_light</item>
        <item name="bald_button_disabled">@color/bald_button_disabled_light</item>
        <item name="bald_button_pill_corners_radius">@dimen/bald_button_pill_corners_radius_light
        </item>
        <item name="bald_decoration_on_background">@color/bald_decoration_on_background_light</item>
        <item name="bald_decoration_on_button">@color/bald_decoration_on_button_light</item>
        <item name="bald_decoration_on_key">@color/bald_decoration_on_key_light</item>
        <item name="bald_hint_on_background">@color/bald_hint_on_background_light</item>
        <item name="bald_hint_on_button">@color/bald_hint_on_button_light</item>
        <item name="bald_selected_on_background">@color/bald_selected_on_background_light</item>
        <item name="bald_text_on_selected">@color/bald_text_on_selected_light</item>
        <item name="bald_stroke_color">@color/bald_stroke_color_light</item>
        <item name="bald_keyboard_key_background">@color/bald_keyboard_key_background_light</item>
        <item name="bald_keyboard_key_pressed_background">
            @color/bald_keyboard_key_pressed_background_light
        </item>
        <item name="bald_stroke_size">@dimen/bald_stroke_size_light</item>
        <item name="bald_text_on_background">@color/bald_text_on_background_light</item>
        <item name="bald_text_on_button">@color/bald_text_on_button_light</item>
        <item name="bald_text_on_key">@color/bald_text_on_key_light</item>
        <item name="bald_edit_text_bg">@color/bald_edit_text_bg_light</item>

        <item name="colorControlHighlight">@color/ripple_light</item>
    </style>

    <style name="AppTheme.Starting" parent="bald_light">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>

    <!--Another Theme to add in the future, right now it looks bad.-->
    <style name="bald_skin" parent="Theme.AppCompat.Light.NoActionBar.FullScreen">
        <item name="bald_key_margin">@dimen/bald_key_margin</item>
        <item name="bald_background">@color/bald_background_skin</item>
        <item name="bald_background_transparent">@color/bald_background_transparent_skin</item>
        <item name="bald_button">@color/bald_button_skin</item>
        <item name="bald_button_clicked">@color/bald_button_clicked_skin</item>
        <item name="bald_button_corners_radius">@dimen/bald_button_corners_radius_skin</item>
        <item name="bald_button_disabled">@color/bald_button_disabled_skin</item>
        <item name="bald_button_pill_corners_radius">@dimen/bald_button_pill_corners_radius_skin
        </item>
        <item name="bald_decoration_on_background">@color/bald_decoration_on_background_skin</item>
        <item name="bald_decoration_on_button">@color/bald_decoration_on_button_skin</item>
        <item name="bald_decoration_on_key">@color/bald_decoration_on_key_skin</item>
        <item name="bald_hint_on_background">@color/bald_hint_on_background_skin</item>
        <item name="bald_hint_on_button">@color/bald_hint_on_button_skin</item>
        <item name="bald_selected_on_background">@color/bald_selected_on_background_skin</item>
        <item name="bald_text_on_selected">@color/bald_text_on_selected_skin</item>
        <item name="bald_stroke_color">@color/bald_stroke_color_skin</item>
        <item name="bald_keyboard_key_background">@color/bald_keyboard_key_background_skin</item>
        <item name="bald_stroke_size">@dimen/bald_stroke_size_skin</item>
        <item name="bald_text_on_background">@color/bald_text_on_background_skin</item>
        <item name="bald_text_on_button">@color/bald_text_on_button_skin</item>
        <item name="bald_text_on_key">@color/bald_text_on_key_skin</item>
    </style>

    <style name="bald_dark" parent="Theme.AppCompat.Light.NoActionBar.FullScreen">
        <item name="bald_key_margin">@dimen/bald_key_margin</item>
        <item name="bald_background">@color/bald_background_dark</item>
        <item name="bald_background_transparent">@color/bald_background_transparent_dark</item>
        <item name="bald_button">@color/bald_button_dark</item>
        <item name="bald_button_clicked">@color/bald_button_clicked_dark</item>
        <item name="bald_button_corners_radius">@dimen/bald_button_corners_radius_dark</item>
        <item name="bald_button_disabled">@color/bald_button_disabled_dark</item>
        <item name="bald_button_pill_corners_radius">@dimen/bald_button_pill_corners_radius_dark
        </item>
        <item name="bald_decoration_on_background">@color/bald_decoration_on_background_dark</item>
        <item name="bald_decoration_on_button">@color/bald_decoration_on_button_dark</item>
        <item name="bald_decoration_on_key">@color/bald_decoration_on_key_dark</item>
        <item name="bald_hint_on_background">@color/bald_hint_on_background_dark</item>
        <item name="bald_hint_on_button">@color/bald_hint_on_button_dark</item>
        <item name="bald_selected_on_background">@color/bald_selected_on_background_dark</item>
        <item name="bald_text_on_selected">@color/bald_text_on_selected_dark</item>
        <item name="bald_keyboard_key_pressed_background">
            @color/bald_keyboard_key_pressed_background_dark
        </item>
        <item name="bald_stroke_color">@color/bald_stroke_color_dark</item>
        <item name="bald_keyboard_key_background">@color/bald_keyboard_key_background_dark</item>
        <item name="bald_stroke_size">@dimen/bald_stroke_size_dark</item>
        <item name="bald_text_on_background">@color/bald_text_on_background_dark</item>
        <item name="bald_text_on_button">@color/bald_text_on_button_dark</item>
        <item name="bald_text_on_key">@color/bald_text_on_key_dark</item>
        <item name="bald_edit_text_bg">@color/bald_edit_text_bg_dark</item>

        <item name="colorControlHighlight">@color/ripple_dark</item>
    </style>


    <style name="ScrollStyle">
        <item name="android:fadingEdgeLength">@dimen/transparent_length_in_scrollers</item>
        <item name="android:requiresFadingEdge">vertical</item>
    </style>

    <style name="EditText" parent="BackgroundText.Large">
        <item name="android:textColorHint">?attr/bald_hint_on_background</item>
    </style>

    <style name="BackgroundText">
        <item name="android:textSize">@dimen/small</item>
        <item name="android:textColor">?attr/bald_text_on_background</item>
    </style>

    <style name="BackgroundText.Auto">
        <item name="autoSizeTextType">uniform</item>
    </style>

    <style name="BackgroundText.Huge">
        <item name="android:textSize">@dimen/huge</item>
    </style>

    <style name="BackgroundText.Large">
        <item name="android:textSize">@dimen/large</item>
    </style>

    <style name="BackgroundText.Medium.Plus">
        <item name="android:textSize">@dimen/medium_plus</item>
    </style>

    <style name="BackgroundText.Medium">
        <item name="android:textSize">@dimen/medium</item>
    </style>

    <style name="BackgroundText.Small">
        <item name="android:textSize">@dimen/small</item>
    </style>

    <style name="BackgroundText.Tiny">
        <item name="android:textSize">@dimen/tiny</item>
    </style>

    <style name="ButtonsText">
        <item name="android:textSize">@dimen/small</item>
        <item name="android:textColor">?attr/bald_text_on_button</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="ButtonsText.Medium">
        <item name="android:textSize">@dimen/medium</item>
    </style>

    <style name="ButtonsText.Large">
        <item name="android:textSize">@dimen/large</item>
    </style>

    <style name="ButtonsText.Huge">
        <item name="android:textSize">@dimen/huge</item>
    </style>

    <style name="ButtonsText.Tiny">
        <item name="android:textSize">@dimen/tiny</item>
    </style>

    <style name="ButtonsText.Auto">
        <item name="autoSizeTextType">uniform</item>
    </style>

    <style name="Bald.Button" parent="BackgroundText.Medium.Plus">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">12dp</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_button</item>
    </style>

    <style name="Bald.Button.FullWidth" parent="Bald.Button">
        <item name="android:layout_width">match_parent</item>
    </style>

    <style name="BaldActionBar" parent="@android:style/Widget.Holo.Light.ActionBar">
        <item name="android:background">?attr/bald_background</item>
    </style>

    <style name="HomeButtonTile">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">5dp</item>
        <item name="android:background">@drawable/bg_tile_default</item>
        <item name="android:foreground">@drawable/fg_home_button</item>
    </style>

    <style name="HomeButtonTile.AccentGreen" parent="HomeButtonTile">
        <item name="android:background">@drawable/bg_tile_green_gradient</item>
    </style>

    <style name="HomeButtonTile.AccentBlue" parent="HomeButtonTile">
        <item name="android:background">@drawable/bg_tile_blue_gradient</item>
    </style>

    <style name="HomeButtonTile.AccentPurple" parent="HomeButtonTile">
        <item name="android:background">@drawable/bg_tile_purple_gradient</item>
    </style>

    <style name="AboutSectionTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">38dp</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:padding">5dp</item>
        <item name="android:textAlignment">viewStart</item>
        <item name="android:textColor">?attr/bald_text_on_background</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:background">@drawable/divider</item>
    </style>

    <style name="LinkRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">8dp</item>
        <item name="android:padding">10dp</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:textAlignment">viewStart</item>
        <item name="android:textColor">?attr/bald_text_on_button</item>
        <item name="android:textSize">19sp</item>
        <item name="android:foreground">?android:attr/selectableItemBackgroundBorderless</item>
    </style>

    <style name="LinkRow.Icon" parent="LinkRow">
        <item name="android:drawablePadding">12dp</item>
    </style>

</resources>
